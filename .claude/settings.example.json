{
  "$schema": "https://claudecode.io/schema/settings.json",
  "_comment": "Optional project-scoped AideMemo dogfooding hooks. Copy this file to .claude/settings.json to activate. Scripts live in ~/.claude/hooks/ (copy them from aidememo-skill/hooks/; see aidememo-skill/hooks/README.md). Hooks soft-fail if the aidememo binary or store is missing.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/aidememo-session-start.py",
            "statusMessage": "aidememo: loading wiki context..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/aidememo-post-tool.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/aidememo-extract-facts.py"
          }
        ]
      }
    ]
  }
}
