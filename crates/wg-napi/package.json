{
  "name": "wg-napi",
  "version": "0.1.0",
  "description": "Node.js bindings for Wiki-Graph (wg) — local knowledge graph for LLM agents",
  "main": "index.js",
  "types": "index.d.ts",
  "homepage": "https://github.com/taeyun16/wg#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taeyun16/wg.git",
    "directory": "crates/wg-napi"
  },
  "bugs": {
    "url": "https://github.com/taeyun16/wg/issues"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "license": "MIT OR Apache-2.0",
  "engines": {
    "node": ">= 16"
  },
  "keywords": [
    "knowledge-graph",
    "wiki",
    "search",
    "bm25",
    "semantic",
    "mcp",
    "llm",
    "napi"
  ],
  "napi": {
    "name": "wg-napi",
    "triples": {
      "defaults": false,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release --js index.js --dts index.d.ts",
    "build:debug": "napi build --platform --js index.js --dts index.d.ts",
    "test": "node tests/smoke.js"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  }
}
